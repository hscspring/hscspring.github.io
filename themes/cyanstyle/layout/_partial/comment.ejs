<% if (!index && post.comments && theme.waline && theme.waline.serverURL){ %>
<section id="comment">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@waline/client@3/dist/waline.css">
  <div id="waline"></div>
  <script type="module">
    import { init } from 'https://cdn.jsdelivr.net/npm/@waline/client@3/dist/waline.js';
    init({
      el: '#waline',
      serverURL: '<%= theme.waline.serverURL %>',
      lang: 'zh-CN',
      path: window.location.pathname,
      emoji: [
        'https://cdn.jsdelivr.net/gh/walinejs/emojis@1.1.0/weibo',
        'https://cdn.jsdelivr.net/gh/walinejs/emojis@1.1.0/bilibili'
      ],
      reaction: true,
      pageview: false,
      comment: true
    });
  </script>
</section>
<% } %>
