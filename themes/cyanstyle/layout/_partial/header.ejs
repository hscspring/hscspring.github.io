<header id="masthead" class="site-header" role="banner">
    <hgroup>
      <h1 class="site-title">
        <a href="<%- url_for() %>" title="<%= config.title %>" rel="home"><%= config.title %></a>
      </h1>
      <% if (theme.subtitle){ %>
        <h2 class="site-description">
          <a href="<%- url_for() %>" id="subtitle"><%= theme.subtitle %></a>
        </h2>
      <% } else { %>
        <h2 class="site-description"><span id="hitokoto">...</span></h2>
        <script>
          (function () {
            fetch('https://v1.hitokoto.cn/?c=i&c=k&encode=json')
              .then(function (r) { return r.json(); })
              .then(function (d) {
                var el = document.getElementById('hitokoto');
                if (el && d && d.hitokoto) {
                  var from = d.from_who ? d.from_who + (d.from ? '《' + d.from + '》' : '')
                                        : (d.from || '');
                  el.textContent = d.hitokoto + (from ? ' —— ' + from : '');
                }
              })
              .catch(function () {});
          })();
        </script>
      <% } %>
    </hgroup>

    <nav id="site-navigation" class="main-navigation" role="navigation">
            <button class="menu-toggle">菜单</button>
            <a class="assistive-text" href="/#content" title="跳至内容">跳至内容</a><!--TODO-->
            <div class="menu-main-container">
                <ul id="menu-main" class="nav-menu">
                <% for (var i in theme.menu){ %>
                    <li class="menu-item menu-item-type-post_type menu-item-object-page"><a href="<%- url_for(theme.menu[i]) %>"><%= i %></a></li>
                <% } %>
                </ul>
            </div>
    </nav>
</header>